# Raw source data can be large, licensed, or sensitive.
data/raw/
data/manual_get_resources

# Keep processed datasets versioned.
!data/processed/
!data/processed/**

# Python cache and test artifacts.
__pycache__/
*.py[cod]
.pytest_cache/

# Local environments and machine-specific settings.
.env
.venv/
venv/

# Generated notebook checkpoints.
.ipynb_checkpoints/

# PyInstaller / streamlit-desktop-app build artifacts (the exe ships via
# GitHub Releases, never committed to the repo).
build/
dist/
*.spec

documents/
.vscode/
.claude/
.codex